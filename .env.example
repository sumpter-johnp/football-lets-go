# Copy to .env and fill in. .env is gitignored — never commit real values.

# Free key: https://collegefootballdata.com/key
CFBD_API_KEY=your_key_here

# Supabase dashboard → Connect → Session pooler URI (works on IPv4 networks;
# the direct db.<ref>.supabase.co host is IPv6-only). Includes the DB password.
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
